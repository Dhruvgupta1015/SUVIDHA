# ── Node / npm ──────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Build output ─────────────────────────────
dist/
dist-ssr/

# ── Environment files (NEVER commit secrets) ─
.env
.env.local
.env.production
.env.*.local
backend/.env

# ── Uploaded files (runtime data, not source) ─
backend/uploads/*
!backend/uploads/.gitkeep

# ── Archives (do not commit zip files) ───────
*.zip

# ── Editor ───────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# ── Vercel ───────────────────────────────────
.vercel/
